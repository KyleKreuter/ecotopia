# Database
DB_USERNAME=ecotopia
DB_PASSWORD=ecotopia

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key

# HuggingFace
HF_TOKEN=your_huggingface_token
HUGGINGFACE_API_KEY=your_huggingface_token

# Fine-tuned model endpoints (HuggingFace Inference Endpoints)
EXTRACTION_ENDPOINT=https://your-8b-extract-endpoint.endpoints.huggingface.cloud
CITIZEN_ENDPOINT=https://your-24b-citizen-endpoint.endpoints.huggingface.cloud

# ElevenLabs TTS (optional, citizen voice reactions)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Weights & Biases (optional, for training/eval tracking)
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=hackathon-london-nolan-2026

# AWS Bedrock (optional, for data generation)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
